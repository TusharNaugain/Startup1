# Copy this file to .env for local development.
# .env is gitignored — never commit real secrets.
# On Railway, set these in the Project → Variables tab.

# ─── Flask ────────────────────────────────────────────────────────────────
FLASK_ENV=production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ─── Database ─────────────────────────────────────────────────────────────
# Railway Postgres add-on injects DATABASE_URL automatically.
# Locally you can leave this unset — it will fall back to sqlite:///wizikey.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Admin ────────────────────────────────────────────────────────────────
# Whoever signs up with this email becomes admin (can approve payments)
ADMIN_EMAIL=naugaintushar@gmail.com

# ─── Email (used to notify admin when a payment is submitted) ─────────────
# For Gmail: enable 2FA, then create an App Password
# https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=naugaintushar@gmail.com
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=naugaintushar@gmail.com
